# John Galt v2.0 — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env — ele está no .gitignore

# OpenRouter (LLM)
OPENROUTER_API_KEY=seu_openrouter_api_key_aqui

# Telegram (alertas)
TELEGRAM_BOT_TOKEN=seu_bot_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# CoinStats (preços cripto)
COINSTATS_API_KEY=sua_api_key_aqui

# BRAPI (cotações B3)
BRAPI_TOKEN=seu_token_aqui

# ZeroClaw (workspace do agente)
ZEROCLAW_WORKSPACE=/root/.zeroclaw/workspace
