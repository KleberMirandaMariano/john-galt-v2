# John Galt v2 - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas chaves reais:
#   cp .env.example .env

# === ANTHROPIC (preferido para Reflection Engine) ===
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === OPENROUTER (usado pelo training/validate_behavior.py) ===
# Obtenha em: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === DADOS DE MERCADO ===
# BRAPI (cotações B3) — obtenha em: https://brapi.dev/
# BRAPI_TOKEN=your_token_here

# === TELEGRAM ===
# Token do bot Telegram (obtenha via @BotFather)
TELEGRAM_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=1808474055

# === CONFIGURAÇÕES GERAIS ===
# Timeout em segundos para requisições yfinance
YFINANCE_TIMEOUT=30
